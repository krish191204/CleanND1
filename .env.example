# ===== CleanND Environment Configuration =====
# Copy to .env and fill in real values. NEVER commit .env.

# Twitter / X API (third-party: twitterapi.io)
TWITTER_API_BASE=https://api.twitterapi.io
TWITTER_API_KEY=your_twitterapi_io_key_here
TWITTER_API_KEY_HEADER=X-API-Key

# Database
DATABASE_URL=sqlite:///./data/cleannd.db
# For production:
# DATABASE_URL=postgresql://cleannd:password@localhost:5432/cleannd

# Redis (caching + queues)
REDIS_URL=redis://localhost:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change_me_to_a_long_random_string

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ML
BOT_MODEL_PATH=./ml/artifacts/bot_classifier.joblib
CREDIBILITY_MODEL_PATH=./ml/artifacts/credibility.joblib
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2
ACTIVE_LEARNING_MARGIN_THRESHOLD=0.15
REVIEW_QUEUE_BATCH_SIZE=50

# Pipeline
MIN_FOLLOWERS=500
DEFAULT_LANG=en
MAX_HASHTAGS=5
MAX_URLS=2
CREDIBILITY_HIGH_THRESHOLD=0.75
CREDIBILITY_MEDIUM_THRESHOLD=0.45
SURFACE_MIN_CREDIBILITY=medium
NOISE_REJECT_THRESHOLD=0.55

# Software focus stage (Stage 0) — broader software sphere
SOFTWARE_FOCUS_ENABLED=true
SOFTWARE_MIN_FOLLOWERS=100
SOFTWARE_MIN_ACCOUNT_AGE_DAYS=30
SOFTWARE_MIN_ENGAGEMENT=5
SOFTWARE_KNOWN_ACCOUNTS_PATH=./data/known_software_accounts.json
SOFTWARE_REQUIRE_ALL_SIGNALS=false
SOFTWARE_CHECK_RETWEETS=true
SOFTWARE_CHECK_ENGAGEMENT=true
SOFTWARE_CHECK_SCAM=true
SOFTWARE_CHECK_PROFILE_METADATA=true

# Mock auto-seed (kiosk mode) — keeps the dashboard populated without
# manual '+15 mock' clicks. A background task checks every interval;
# if the surfaced feed drops below MIN_FEED_SIZE, it runs a small
# mock ingest to top it up. Disable in CI / tests with 'false'.
MOCK_AUTO_SEED_ENABLED=true
MOCK_AUTO_SEED_MIN_FEED_SIZE=5
MOCK_AUTO_SEED_CHECK_INTERVAL_SECONDS=60
MOCK_AUTO_SEED_BATCH_SIZE=15
MOCK_AUTO_SEED_INITIAL_DELAY_SECONDS=2

# Real-ingest background poller — periodically calls twitterapi.io with
# the curated queries below and runs results through the pipeline.
# Credit-conscious defaults: 3 high-yield beats, 10 min interval.
# Disable in CI / tests / production (paid-plan-only) with 'false'.
REAL_INGEST_ENABLED=true
REAL_INGEST_INTERVAL_SECONDS=600
REAL_INGEST_INITIAL_DELAY_SECONDS=5
REAL_INGEST_QUERY_DELAY_SECONDS=7
REAL_INGEST_QUERIES=["ai_news","china_ai","tech"]
REAL_INGEST_MAX_PER_QUERY=25
REAL_INGEST_MAX_PERSIST_PER_CYCLE=30
REAL_INGEST_ERROR_BACKOFF=true